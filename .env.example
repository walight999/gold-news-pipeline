# Copy to .env for local dev. In Actions these are repo secrets.
LINE_CHANNEL_TOKEN=
LINE_NEWS_TARGET=
LINE_HEALTH_TARGET=
GSHEET_ID=
# GSHEET_CREDS = raw JSON of service-account key (paste single-line JSON)
GSHEET_CREDS=
# Optional — enables FRED-backed actual values in post-release calendar alerts.
# Free signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Optional — Claude Haiku primary classifier+Thai rewrite for LINE cards.
ANTHROPIC_API_KEY=
# Optional — Gemini secondary classifier, used when Claude is unavailable
# (e.g. Anthropic spend cap) before the literal-translation fallback.
# Free API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional override for the Gemini model id (default: gemini-2.0-flash).
GEMINI_MODEL=
# Optional — Apify X/Twitter fast-news scraper.
APIFY_TOKEN=
